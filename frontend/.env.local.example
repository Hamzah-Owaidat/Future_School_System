# =============================================================================
# FuturSchool System — Frontend environment variables (Next.js)
# =============================================================================
# Copy this file to `.env.local` in the same folder (frontend/):
#
#   cp .env.local.example .env.local
#
# Never commit `.env.local` — it is listed in .gitignore.
#
# Next.js loads: .env.local, .env.development.local, .env.production.local
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# API (required for the dashboard to call the backend)
# -----------------------------------------------------------------------------

# Base URL of the Express API (must include trailing path to /api)
# Must match backend PORT in backend/.env (e.g. PORT=8080 → http://localhost:8080/api)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/

# -----------------------------------------------------------------------------
# Built-in Next.js variables (optional — usually set by npm scripts, do not copy)
# -----------------------------------------------------------------------------
# NODE_ENV=development          # set automatically: development | production
# NEXT_PUBLIC_VERCEL_URL=        # set on Vercel deployments only
