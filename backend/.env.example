# =============================================================================
# FuturSchool System — Backend environment variables
# =============================================================================
# Copy this file to `.env` in the same folder (backend/) and fill in real values:
#
#   cp .env.example .env
#
# Never commit `.env` — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HTTP port for the Express API (default in code: 3000 if unset)
PORT=8080

# development | production
# - development: API error responses may include stack traces
NODE_ENV=development

# -----------------------------------------------------------------------------
# MySQL database
# Used by: config/database.js, lib/migrateRunner.js, scripts/run-seed.js
# -----------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_NAME=futurschool
DB_USER=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# JWT authentication
# Used by: middleware/auth.js (login + protected routes)
# -----------------------------------------------------------------------------

# REQUIRED in production — use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Token lifetime (jsonwebtoken format: 7d, 24h, 60m, etc.)
JWT_EXPIRE=7d
