{
  "name": "futurschool-system",
  "version": "1.0.0",
  "description": "Express.js backend for FuturSchool System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:fresh": "node scripts/migrate.js fresh",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "db:refresh": "node scripts/migrate.js fresh && node scripts/run-seed.js",
    "db:seed": "node scripts/run-seed.js"
  },
  "keywords": [
    "express",
    "school",
    "system",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "mysql2": "^3.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}

